{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@shadcn/ui": "^0.0.4",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.13.2",
    "lucide-react": "^0.479.0",
    "react": "^18.3.1",
    "react-datepicker": "^8.3.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "react-scripts": "^5.0.1",
    "recharts": "^2.15.2",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "set NODE_OPTIONS=--openssl-legacy-provider && react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:all:coverage": "react-scripts test --watchAll=false --coverage --coverageReporters=text --coverageReporters=text-summary --ci",
    "test:auth:coverage": "react-scripts test --watchAll=false --runTestsByPath src/__tests__/LoginHU212.monitor.test.js src/__tests__/LoginHU212.professor.test.js src/__tests__/LoginHU212.jefe.test.js --coverage --coverageReporters=text --coverageReporters=text-summary --collectCoverageFrom=src/Login.js --ci",
    "test:monitor:login": "react-scripts test --watchAll=false --runTestsByPath src/__tests__/LoginHU212.monitor.test.js --coverage --coverageReporters=text --coverageReporters=text-summary --collectCoverageFrom=src/Login.js --ci",
    "test:professor:login": "react-scripts test --watchAll=false --runTestsByPath src/__tests__/LoginHU212.professor.test.js --coverage --coverageReporters=text --coverageReporters=text-summary --collectCoverageFrom=src/Login.js --ci",
    "test:jefe:login": "react-scripts test --watchAll=false --runTestsByPath src/__tests__/LoginHU212.jefe.test.js --coverage --coverageReporters=text --coverageReporters=text-summary --collectCoverageFrom=src/Login.js --ci",
    "test:roles:login": "react-scripts test --watchAll=false --runTestsByPath src/__tests__/LoginHU212.monitor.test.js src/__tests__/LoginHU212.professor.test.js src/__tests__/LoginHU212.jefe.test.js --coverage --coverageReporters=text --coverageReporters=text-summary --collectCoverageFrom=src/Login.js --ci",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
